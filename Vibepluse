    </div>
  </div>
  <div class="chat-messages" id="chatMessages"></div>
  <div class="chat-input-bar">
    <input type="text" id="chatInput" placeholder="Message likho...">
    <button class="photo-send-btn" onclick="initiatePhotoSend()" title="Photo bhejo (1 credit)">📷</button>
    <button class="send-btn" onclick="sendMsg()">➤</button>
  </div>
</div>

<!-- USER PROFILE PANEL -->
<div id="userProfilePanel">
