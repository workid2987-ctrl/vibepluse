  #toast { position:fixed; bottom:90px; left:50%; transform:translateX(-50%) translateY(20px); background:var(--accent); color:#fff; padding:10px 20px; border-radius:24px; font-size:13px; font-weight:600; opacity:0; transition:.3s; z-index:9999; white-space:nowrap; }
  #toast.show { opacity:1; transform:translateX(-50%) translateY(0); }

  .tag { display:inline-block; background:rgba(124,92,252,.15); color:var(--accent); border-radius:6px; padding:2px 8px; font-size:11px; margin-right:4px; }
