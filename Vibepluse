<body>

<!-- SETUP -->
<div class="screen active" id="setupScreen">
  <div class="setup-card">
    <div class="logo">⚡ VibePulse</div>
    <div class="tagline">Feel the vibe, pulse the world</div>
    <label>Apna Avatar Chuno</label>
    <div class="avatar-pick" id="avatarPick">
      <div class="av-opt" data-av="🧑‍💻">🧑‍💻</div><div class="av-opt" data-av="👩‍🎨">👩‍🎨</div>
      <div class="av-opt" data-av="🧑‍🎤">🧑‍🎤</div><div class="av-opt" data-av="👨‍🚀">👨‍🚀</div>
