  </div>
  <div class="up-posts-section">
    <div class="up-posts-title">Posts</div>
    <div class="up-posts-grid" id="upPostsGrid"></div>
  </div>
</div>

<!-- PEOPLE PANEL -->
<div id="peoplePanel">
  <div class="pp-topbar">
    <span class="back-btn" onclick="closePeoplePanel()">←</span>
