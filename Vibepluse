    <div class="up-cover-bg" id="upCoverBg"></div>
    <div class="up-cover-glow"></div>
    <div class="up-avatar-wrap"><div class="up-avatar" id="upAvatar"></div></div>
  </div>
  <div class="up-body">
    <div id="upOnlineBadge"></div>
    <div class="up-name" id="upName"></div>
    <div class="up-username" id="upUsername"></div>
    <div class="up-bio" id="upBio"></div>
