        <button class="edit-profile-btn" onclick="openEditModal()">✏️ Edit Profile</button>
      </div>
      <div class="profile-name" id="myProfileName"></div>
      <div class="profile-username" id="myProfileUsername"></div>
      <div class="profile-bio" id="myProfileBio"></div>
      <div class="profile-stats">
        <div class="stat"><div class="stat-num" id="statPosts">0</div><div class="stat-label">Posts</div></div>
        <div class="stat" onclick="openPeoplePanel('followers','me')"><div class="stat-num" id="statFollowers">0</div><div class="stat-label">Followers</div></div>
        <div class="stat" onclick="openPeoplePanel('following','me')"><div class="stat-num" id="statFollowing">0</div><div class="stat-label">Following</div></div>
      </div>
    </div>
    <div class="section-title" style="display:flex;align-items:center;gap:8px;">
      Meri Stories
      <button onclick="openStoryCreate()" style="margin-left:auto;padding:5px 14px;background:var(--accent);color:#fff;border:none;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;">+ Nayi Story</button>
    </div>
    <div class="story-row-wrap" id="myStoryRow" style="padding-top:4px"></div>
    <div class="section-title">Mere Posts</div>
    <div id="myPostsFeed"></div>
  </div>

  <div class="bottom-nav">
    <div class="nav-item active" onclick="showPage('explorePage')" id="nav-explore"><span>🔍</span><span>Explore</span></div>
    <div class="nav-item" onclick="showPage('chatPage')" id="nav-chat"><span>💬</span><span>Chat</span></div>
