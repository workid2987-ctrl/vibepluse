  /* PEOPLE PANEL */
  #peoplePanel { position:fixed; inset:0; z-index:400; background:var(--bg); transform:translateY(100%); transition:transform .35s cubic-bezier(.4,0,.2,1); display:flex; flex-direction:column; }
