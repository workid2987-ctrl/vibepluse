      <div class="up-stat" onclick="openPeoplePanel('following',currentViewUserId)"><div class="up-stat-num" id="upFollowing"></div><div class="up-stat-label">Following</div></div>
    </div>
    <div class="up-actions">
      <button class="up-follow-btn" id="upFollowBtn" onclick="toggleFollowFromProfile()"></button>
      <button class="up-msg-btn" onclick="msgFromProfile()">💬</button>
