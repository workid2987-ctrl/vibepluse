    <textarea id="setupBio" placeholder="Apne baare mein kuch batao..."></textarea>
    <button class="btn" onclick="createProfile()">Profile Banao 🚀</button>
  </div>
</div>

<!-- MAIN APP -->
<div class="screen" id="mainScreen">
  <div class="topbar">
    <div class="logo">⚡ VibePulse</div>
    <div class="topbar-actions">
      <div class="credit-badge" onclick="openCreditModal()">
        <span class="credit-icon">⚡</span>
        <span class="credit-num" id="creditDisplay">0</span>
      </div>
      <div class="icon-btn" onclick="showPage('chatPage')">💬</div>
      <div class="icon-btn" onclick="showToast('Koi naya notification nahi!')">🔔</div>
    </div>
  </div>

  <!-- EXPLORE -->
  <div id="explorePage" class="page active">
    <div class="story-row-wrap" id="storyRow"></div>
    <input class="search-bar" placeholder="🔍  Log dhundo..." id="searchBar" oninput="filterUsers()">
    <div class="section-title">Sabse Popular Log 🔥</div>
    <div class="user-grid" id="userGrid"></div>
  </div>

  <!-- CHAT -->
  <div id="chatPage" class="page">
    <div class="section-title">Messages 💬</div>
    <div class="chat-list" id="chatList"></div>
  </div>

  <!-- PROFILE -->
  <div id="profilePage" class="page">
    <div class="profile-cover"><div class="cover-pattern"></div></div>
    <div class="profile-info">
      <div class="profile-avatar-wrap"><div class="profile-avatar" id="myProfileAvatar"></div></div>
