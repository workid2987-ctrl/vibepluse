<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VibePulse</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #13131a;
    --surface2: #1c1c28;
    --border: #2a2a3d;
    --accent: #7c5cfc;
    --accent2: #fc5c7d;
    --gold: #f9c74f;
    --text: #e8e8f0;
    --muted: #6b6b8a;
    --online: #4ade80;
    --radius: 16px;
    --story-gradient: linear-gradient(135deg, #7c5cfc, #fc5c7d, #f9c74f);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; min-height: 100vh; overflow-x: hidden; }

  .screen { display: none; min-height: 100vh; }
  .screen.active { display: flex; }

  /* SETUP */
  #setupScreen {
    flex-direction: column; align-items: center; justify-content: center; padding: 24px;
    background: radial-gradient(ellipse at 30% 20%, #2d1b69 0%, transparent 60%),
                radial-gradient(ellipse at 70% 80%, #4a0e2e 0%, transparent 60%), var(--bg);
  }
  .setup-card {
    background: var(--surface); border: 1px solid var(--border); border-radius: 24px;
    padding: 40px 36px; width: 100%; max-width: 420px; box-shadow: 0 40px 80px rgba(0,0,0,.6);
  }
  .logo {
    font-family: 'Syne', sans-serif; font-size: 30px; font-weight: 800;
    background: var(--story-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    text-align: center; margin-bottom: 6px; letter-spacing: -1px;
  }
  .tagline { text-align:center; color:var(--muted); font-size:13px; margin-bottom:32px; }
  .avatar-pick { display:flex; flex-wrap:wrap; gap:12px; justify-content:center; margin-bottom:24px; }
  .av-opt {
    width:56px; height:56px; border-radius:50%; font-size:28px; display:flex; align-items:center; justify-content:center;
    cursor:pointer; border:3px solid transparent; transition:.2s; background:var(--surface2);
  }
  .av-opt.selected { border-color:var(--accent); transform:scale(1.12); }
  label { font-size:12px; color:var(--muted); letter-spacing:.5px; text-transform:uppercase; display:block; margin-bottom:6px; }
  input[type=text], textarea {
    width:100%; background:var(--surface2); border:1px solid var(--border); border-radius:10px;
    color:var(--text); font-family:'DM Sans',sans-serif; font-size:15px; padding:12px 14px;
    outline:none; transition:border-color .2s; margin-bottom:16px;
  }
  input[type=text]:focus, textarea:focus { border-color:var(--accent); }
  textarea { resize:vertical; min-height:72px; }
  .btn {
    display:block; width:100%; background:var(--accent); color:#fff; border:none; border-radius:12px;
    padding:14px; font-family:'Syne',sans-serif; font-size:15px; font-weight:700; cursor:pointer; transition:.2s; letter-spacing:.5px;
  }
  .btn:hover { background:#6948e8; transform:translateY(-1px); }
  .btn-outline { background:transparent; border:1px solid var(--border); color:var(--muted); }
  .btn-outline:hover { border-color:var(--accent); color:var(--accent); background:transparent; }

  /* MAIN */
  #mainScreen { flex-direction:column; }
  .topbar {
    position:sticky; top:0; z-index:100; background:rgba(10,10,15,.85); backdrop-filter:blur(20px);
    border-bottom:1px solid var(--border); display:flex; align-items:center; padding:12px 16px; gap:12px;
  }
  .topbar .logo { margin:0; font-size:22px; }
  .topbar-actions { margin-left:auto; display:flex; gap:10px; align-items:center; }
  .icon-btn {
    width:38px; height:38px; border-radius:50%; background:var(--surface2); border:1px solid var(--border);
    color:var(--text); display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:17px; transition:.2s;
  }
  .icon-btn:hover { border-color:var(--accent); color:var(--accent); }

  /* CREDIT BADGE */
  .credit-badge {
    display:flex; align-items:center; gap:5px;
    background:linear-gradient(135deg,#f9c74f22,#f9c74f11);
    border:1px solid #f9c74f44;
    border-radius:20px; padding:5px 12px; cursor:pointer;
    transition:.2s;
  }
  .credit-badge:hover { border-color:var(--gold); }
  .credit-icon { font-size:14px; }
  .credit-num { font-family:'Syne',sans-serif; font-size:13px; font-weight:700; color:var(--gold); }

  /* NAV */
  .bottom-nav {
    position:fixed; bottom:0; left:0; right:0; z-index:100; background:rgba(10,10,15,.92);
    backdrop-filter:blur(20px); border-top:1px solid var(--border); display:flex;
  }
  .nav-item {
    flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;
    padding:10px 4px 6px; cursor:pointer; color:var(--muted); font-size:10px; gap:3px; transition:color .2s;
    -webkit-tap-highlight-color:transparent;
  }
  .nav-item span:first-child { font-size:21px; }
  .nav-item.active { color:var(--accent); }

  /* PAGES */
  .page { display:none; padding:12px 12px 90px; animation:fadeUp .3s ease; }
  .page.active { display:block; }
  @keyframes fadeUp { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }

  /* STORY ROW */
  .story-row-wrap { margin:0 -12px; padding:14px 12px 16px; overflow-x:auto; scrollbar-width:none; display:flex; gap:14px; margin-bottom:10px; }
  .story-row-wrap::-webkit-scrollbar { display:none; }
  .story-bubble-wrap { display:flex; flex-direction:column; align-items:center; gap:5px; cursor:pointer; flex-shrink:0; }
  .story-ring { width:64px; height:64px; border-radius:50%; padding:2.5px; background:var(--story-gradient); transition:transform .2s; }
  .story-ring.seen { background:var(--border); }
  .story-ring.my-story { background:linear-gradient(135deg,#4ade80,#22d3ee); }
  .story-ring:active { transform:scale(.93); }
  .story-inner { width:100%; height:100%; border-radius:50%; background:var(--surface2); border:2px solid var(--bg); display:flex; align-items:center; justify-content:center; font-size:30px; }
  .story-label { font-size:11px; color:var(--muted); max-width:64px; text-align:center; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .story-add-btn { width:26px; height:26px; background:var(--accent); border-radius:50%; position:absolute; bottom:-2px; right:-2px; border:2px solid var(--bg); display:flex; align-items:center; justify-content:center; font-size:14px; color:#fff; font-weight:700; }
  .my-story-wrap { position:relative; }

  /* STORY VIEWER */
  #storyViewer { position:fixed; inset:0; z-index:500; background:#000; display:flex; flex-direction:column; transform:translateY(100%); transition:transform .35s cubic-bezier(.4,0,.2,1); }
  #storyViewer.open { transform:translateY(0); }
  .sv-topbar { position:absolute; top:0; left:0; right:0; z-index:10; padding:14px 14px 10px; background:linear-gradient(to bottom,rgba(0,0,0,.7),transparent); }
  .sv-progress-row { display:flex; gap:4px; margin-bottom:12px; }
  .sv-progress-bar { flex:1; height:2.5px; background:rgba(255,255,255,.3); border-radius:2px; overflow:hidden; }
  .sv-progress-fill { height:100%; background:#fff; width:0%; transition:width linear; }
  .sv-user-row { display:flex; align-items:center; gap:10px; }
  .sv-avatar { font-size:32px; }
  .sv-user-info { flex:1; }
  .sv-name { font-weight:700; font-size:14px; color:#fff; }
  .sv-time { font-size:11px; color:rgba(255,255,255,.6); }
  .sv-close { font-size:22px; cursor:pointer; color:rgba(255,255,255,.8); padding:4px; }
  .sv-content { flex:1; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg,#1a0533,#3d1040,#1a2040); user-select:none; position:relative; }
  .sv-content.style2 { background:linear-gradient(135deg,#001a33,#0d2040,#001a1a); }
  .sv-content.style3 { background:linear-gradient(135deg,#331a00,#402010,#1a3300); }
  .sv-content.style4 { background:linear-gradient(135deg,#0a0a2e,#1a0a3d,#0a1a2e); }
  .sv-content.style5 { background:linear-gradient(135deg,#0a1a0a,#1a2a10,#0a1520); }
  .sv-story-text { position:absolute; bottom:80px; left:0; right:0; text-align:center; color:#fff; font-family:'Syne',sans-serif; font-size:22px; font-weight:700; text-shadow:0 2px 12px rgba(0,0,0,.8); padding:0 24px; }
  .sv-tap-left,.sv-tap-right { position:absolute; top:0; bottom:0; width:40%; z-index:5; cursor:pointer; }
  .sv-tap-left { left:0; } .sv-tap-right { right:0; }
  .sv-bottom-bar { padding:14px 16px 24px; background:linear-gradient(to top,rgba(0,0,0,.7),transparent); display:flex; align-items:center; gap:12px; }
  .sv-viewers-btn { display:flex; align-items:center; gap:6px; color:rgba(255,255,255,.8); font-size:13px; cursor:pointer; background:rgba(255,255,255,.12); border:1px solid rgba(255,255,255,.2); border-radius:20px; padding:6px 14px; transition:.2s; }

  /* STORY CREATE */
  #storyCreateModal { position:fixed; inset:0; z-index:600; background:rgba(0,0,0,.85); backdrop-filter:blur(12px); display:none; align-items:flex-end; justify-content:center; }
  #storyCreateModal.open { display:flex; }
  .sc-sheet { background:var(--surface); border:1px solid var(--border); border-radius:24px 24px 0 0; padding:24px; width:100%; max-width:480px; animation:slideUp .3s ease; }
  .sc-title { font-family:'Syne',sans-serif; font-size:17px; font-weight:700; margin-bottom:14px; }
  .emoji-picker { display:flex; flex-wrap:wrap; gap:10px; margin-bottom:14px; }
  .ep-opt { width:48px; height:48px; border-radius:12px; background:var(--surface2); border:2px solid transparent; font-size:26px; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:.15s; }
  .ep-opt.selected { border-color:var(--accent); transform:scale(1.1); }

  /* STORY VIEWERS SHEET */
  #storyViewersSheet { position:fixed; inset:0; z-index:700; background:rgba(0,0,0,.7); backdrop-filter:blur(8px); display:none; align-items:flex-end; justify-content:center; }
  #storyViewersSheet.open { display:flex; }
  .svs-sheet { background:var(--surface); border:1px solid var(--border); border-radius:24px 24px 0 0; width:100%; max-width:480px; max-height:60vh; animation:slideUp .3s ease; display:flex; flex-direction:column; overflow:hidden; }
  .svs-header { padding:18px 20px 12px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
  .svs-title { font-family:'Syne',sans-serif; font-size:16px; font-weight:700; }
  .svs-close { font-size:20px; cursor:pointer; color:var(--muted); }
  .svs-list { overflow-y:auto; padding:10px 16px 20px; display:flex; flex-direction:column; gap:10px; }
  .svs-item { display:flex; align-items:center; gap:12px; }
  .svs-av { font-size:28px; } .svs-info { flex:1; }
  .svs-name { font-weight:600; font-size:14px; } .svs-time { font-size:11px; color:var(--muted); }

  /* SECTION TITLE */
  .section-title { font-family:'Syne',sans-serif; font-size:16px; font-weight:700; margin-bottom:14px; color:var(--text); }

  /* USER GRID */
  .user-grid { display:flex; flex-direction:column; gap:10px; }
  .user-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:14px; display:flex; align-items:center; gap:12px; transition:border-color .2s; }
  .user-card:hover { border-color:var(--accent); }
  .user-card-av { font-size:36px; cursor:pointer; }
  .user-card-info { flex:1; cursor:pointer; }
  .user-card-name { font-weight:600; font-size:15px; }
  .user-card-bio { font-size:12px; color:var(--muted); margin-top:2px; }
  .follow-btn { padding:7px 14px; border-radius:8px; border:1px solid var(--accent); background:transparent; color:var(--accent); font-size:12px; font-weight:600; cursor:pointer; transition:.2s; white-space:nowrap; }
  .follow-btn:hover,.follow-btn.following { background:var(--accent); color:#fff; }

  /* CHAT LIST */
  .chat-list { display:flex; flex-direction:column; gap:8px; }
  .chat-item { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:13px 14px; display:flex; align-items:center; gap:12px; cursor:pointer; transition:.2s; }
  .chat-item:hover { border-color:var(--accent); }
  .chat-av { font-size:34px; position:relative; }
  .online-dot { position:absolute; bottom:1px; right:1px; width:10px; height:10px; border-radius:50%; background:var(--online); border:2px solid var(--surface); }
  .chat-info { flex:1; min-width:0; }
  .chat-name { font-weight:600; font-size:14px; }
  .chat-preview { font-size:12px; color:var(--muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .chat-meta { text-align:right; }
  .chat-time { font-size:11px; color:var(--muted); }
  .chat-badge { background:var(--accent); color:#fff; border-radius:50%; font-size:10px; width:18px; height:18px; display:flex; align-items:center; justify-content:center; margin-top:4px; margin-left:auto; }

  /* CHAT WINDOW */
  #chatWindow { position:fixed; inset:0; z-index:200; background:var(--bg); display:flex; flex-direction:column; transform:translateX(100%); transition:transform .3s cubic-bezier(.4,0,.2,1); }
  #chatWindow.open { transform:translateX(0); }
  .chat-topbar { background:rgba(10,10,15,.9); backdrop-filter:blur(20px); border-bottom:1px solid var(--border); padding:10px 14px; display:flex; align-items:center; gap:10px; }
  .back-btn { font-size:22px; cursor:pointer; color:var(--muted); flex-shrink:0; }
  .back-btn:hover { color:var(--text); }
  .chat-user-info { flex:1; }
  .chat-user-name { font-weight:700; font-size:15px; }
  .chat-status { font-size:11px; color:var(--online); }
  .chat-call-btns { display:flex; gap:8px; }
  .call-btn {
    width:36px; height:36px; border-radius:50%; border:none; cursor:pointer;
    display:flex; align-items:center; justify-content:center; font-size:16px; transition:.2s;
  }
  .call-btn.audio { background:rgba(74,222,128,.15); color:var(--online); border:1px solid rgba(74,222,128,.3); }
  .call-btn.video { background:rgba(124,92,252,.15); color:var(--accent); border:1px solid rgba(124,92,252,.3); }
  .call-btn:hover { transform:scale(1.1); }
  .chat-messages { flex:1; overflow-y:auto; padding:16px; display:flex; flex-direction:column; gap:10px; scrollbar-width:none; }
  .msg-bubble { max-width:72%; padding:10px 14px; border-radius:18px; font-size:14px; line-height:1.45; animation:bubbleIn .2s ease; }
  @keyframes bubbleIn { from{opacity:0;transform:scale(.9)} to{opacity:1;transform:scale(1)} }
  .msg-bubble.sent { background:var(--accent); color:#fff; align-self:flex-end; border-bottom-right-radius:4px; }
  .msg-bubble.received { background:var(--surface2); color:var(--text); align-self:flex-start; border-bottom-left-radius:4px; }
  .msg-time { font-size:10px; opacity:.6; margin-top:4px; }

  /* PHOTO MESSAGE */
  .msg-photo { max-width:80%; align-self:flex-end; animation:bubbleIn .2s ease; }
  .msg-photo-inner {
    background:var(--surface2); border:1px solid var(--border); border-radius:16px; overflow:hidden;
    position:relative; cursor:pointer;
  }
  .msg-photo-emoji { font-size:80px; padding:20px; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg,var(--surface2),var(--bg)); min-width:140px; min-height:120px; }
  .msg-photo-overlay { position:absolute; inset:0; background:rgba(0,0,0,.5); display:flex; flex-direction:column; align-items:center; justify-content:center; color:#fff; }
  .msg-photo-tap { font-size:12px; font-weight:600; }
  .msg-photo-credits { font-size:11px; color:var(--gold); margin-top:3px; }
  .msg-photo-viewed { font-size:11px; color:var(--muted); margin-top:4px; }
  .msg-photo-deleted { background:var(--surface2); border:1px dashed var(--border); border-radius:16px; padding:14px 18px; display:flex; align-items:center; gap:8px; max-width:80%; align-self:flex-end; }

  .chat-input-bar { border-top:1px solid var(--border); padding:10px 12px; display:flex; gap:8px; align-items:center; background:var(--surface); }
  .chat-input-bar input { flex:1; margin:0; border-radius:24px; padding:10px 16px; font-size:14px; }
  .send-btn { width:42px; height:42px; border-radius:50%; background:var(--accent); border:none; color:#fff; font-size:18px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:.2s; flex-shrink:0; }
  .send-btn:hover { background:#6948e8; }
  .photo-send-btn {
    width:42px; height:42px; border-radius:50%;
    background:rgba(249,199,79,.15); border:1px solid rgba(249,199,79,.4);
    color:var(--gold); font-size:18px; cursor:pointer;
    display:flex; align-items:center; justify-content:center; transition:.2s; flex-shrink:0;
  }
  .photo-send-btn:hover { background:rgba(249,199,79,.25); }

  /* CALL SCREEN */
  #callScreen {
    position:fixed; inset:0; z-index:800;
    background:radial-gradient(ellipse at 30% 20%,#1a0a3d,transparent 60%),radial-gradient(ellipse at 70% 80%,#2d0a1a,transparent 60%),#080810;
    display:flex; flex-direction:column; align-items:center; justify-content:space-between;
    padding:60px 24px 48px;
    transform:translateY(100%); transition:transform .4s cubic-bezier(.4,0,.2,1);
  }
  #callScreen.open { transform:translateY(0); }
  .call-type-badge {
    font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;
    color:var(--muted); background:var(--surface2); border-radius:20px; padding:4px 14px; border:1px solid var(--border);
  }
  .call-center { display:flex; flex-direction:column; align-items:center; gap:20px; }
  .call-avatar-big { font-size:90px; filter:drop-shadow(0 8px 32px rgba(124,92,252,.4)); }
  .call-name { font-family:'Syne',sans-serif; font-size:28px; font-weight:800; }
  .call-status-txt { color:var(--muted); font-size:14px; }
  /* Video call display */
  .video-feeds { display:flex; flex-direction:column; gap:12px; align-items:center; width:100%; }
  .video-main { width:100%; max-width:320px; aspect-ratio:9/16; border-radius:20px; background:linear-gradient(135deg,#1a0a3d,#0a1a1a); display:flex; align-items:center; justify-content:center; font-size:72px; border:2px solid var(--border); position:relative; overflow:hidden; }
  .video-main-label { position:absolute; bottom:12px; left:12px; font-size:12px; color:rgba(255,255,255,.7); background:rgba(0,0,0,.4); border-radius:6px; padding:3px 8px; }
  .video-self { width:90px; height:120px; border-radius:12px; background:linear-gradient(135deg,#1a2a1a,#0a1a0a); display:flex; align-items:center; justify-content:center; font-size:32px; border:2px solid var(--accent); position:absolute; bottom:200px; right:20px; }
  .call-controls { display:flex; gap:16px; align-items:center; }
  .ctrl-btn {
    width:60px; height:60px; border-radius:50%; border:none; cursor:pointer;
    display:flex; align-items:center; justify-content:center; font-size:22px; transition:.2s;
  }
  .ctrl-btn:hover { transform:scale(1.08); }
  .ctrl-btn.mute { background:var(--surface2); border:1px solid var(--border); color:var(--text); }
  .ctrl-btn.camera { background:var(--surface2); border:1px solid var(--border); color:var(--text); }
  .ctrl-btn.end { background:#ff3b3b; color:#fff; width:70px; height:70px; font-size:26px; }
  .ctrl-btn.speaker { background:var(--surface2); border:1px solid var(--border); color:var(--text); }

  /* CREDIT MODAL */
  #creditModal { position:fixed; inset:0; z-index:900; background:rgba(0,0,0,.85); backdrop-filter:blur(12px); display:none; align-items:center; justify-content:center; padding:24px; }
  #creditModal.open { display:flex; }
  .credit-sheet { background:var(--surface); border:1px solid var(--border); border-radius:24px; padding:28px 24px; width:100%; max-width:380px; }
  .credit-header { display:flex; align-items:center; gap:12px; margin-bottom:20px; }
  .credit-icon-big { font-size:36px; }
  .credit-title { font-family:'Syne',sans-serif; font-size:20px; font-weight:800; }
  .credit-subtitle { color:var(--muted); font-size:13px; }
  .credit-balance { background:var(--surface2); border:1px solid var(--border); border-radius:16px; padding:16px; margin-bottom:20px; text-align:center; }
  .credit-balance-num { font-family:'Syne',sans-serif; font-size:42px; font-weight:800; color:var(--gold); }
  .credit-balance-label { color:var(--muted); font-size:13px; }
  .credit-how { margin-bottom:20px; }
  .credit-how-title { font-family:'Syne',sans-serif; font-size:13px; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.5px; margin-bottom:10px; }
  .credit-row { display:flex; align-items:center; gap:10px; padding:10px; background:var(--surface2); border-radius:10px; margin-bottom:8px; }
  .credit-row-icon { font-size:20px; }
  .credit-row-text { flex:1; font-size:13px; }
  .credit-row-amt { font-family:'Syne',sans-serif; font-size:13px; font-weight:700; }
  .credit-row-amt.earn { color:var(--online); }
  .credit-row-amt.spend { color:var(--accent2); }

  /* PROFILE */
  .profile-cover { height:140px; background:linear-gradient(135deg,#2d1b69,#4a0e2e,#1a1a4e); border-radius:var(--radius); margin-bottom:-36px; position:relative; overflow:hidden; }
  .cover-pattern { position:absolute; inset:0; background-image:radial-gradient(circle at 20% 50%,rgba(124,92,252,.4) 0%,transparent 50%),radial-gradient(circle at 80% 20%,rgba(252,92,125,.3) 0%,transparent 40%); }
