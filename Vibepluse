  .up-cover-glow { position:absolute; inset:0; background-image:radial-gradient(circle at 25% 40%,rgba(124,92,252,.5) 0%,transparent 55%),radial-gradient(circle at 75% 60%,rgba(252,92,125,.4) 0%,transparent 50%); }
  .up-avatar-wrap { position:absolute; bottom:-32px; left:20px; }
  .up-avatar { width:72px; height:72px; border-radius:50%; background:var(--surface2); border:3px solid var(--bg); display:flex; align-items:center; justify-content:center; font-size:40px; box-shadow:0 8px 32px rgba(0,0,0,.5); }
  .up-body { padding:44px 20px 20px; background:var(--surface); border-bottom:1px solid var(--border); }
  .up-name { font-family:'Syne',sans-serif; font-size:22px; font-weight:800; margin-bottom:2px; }
  .up-username { color:var(--muted); font-size:13px; margin-bottom:10px; }
  .up-bio { font-size:14px; line-height:1.55; color:var(--text); margin-bottom:16px; }
  .up-stats { display:flex; gap:0; background:var(--surface2); border-radius:12px; border:1px solid var(--border); overflow:hidden; margin-bottom:16px; }
  .up-stat { flex:1; text-align:center; padding:12px 8px; border-right:1px solid var(--border); cursor:pointer; transition:background .15s; }
  .up-stat:hover { background:rgba(124,92,252,.1); }
