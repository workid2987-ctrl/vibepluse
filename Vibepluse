<div id="toast"></div>

<script>
// ═══════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════
let me = null, selectedAvatar = '🧑‍💻', editAvatar = null;
let currentChatUser = null, chats = {}, myPosts = [];
let currentViewUserId = null, following = new Set();
let credits = 0;
let stories = [], seenStories = new Set();
let currentStorySlide = 0, storyQueue = [], storyTimer = null;
let selectedStoryEmoji = '🌅';
let pendingPhotoEmoji = null;
let isMuted = false, isCameraOff = false, callType = 'audio', callTimer = null, callSeconds = 0;
const STORY_DURATION = 5000;
const storyBgs = ['','style2','style3','style4','style5'];

const sampleUsers = [
  { id:'u1', name:'Priya Sharma', username:'@priya_s', avatar:'👩‍🎨', bio:'Designer & Artist 🎨 | Mumbai.', followers:1243, following:389, posts:47, online:true, samplePosts:['🌸','🎨','✨','🌅','💫','🎭'], followerIds:['u2','u3','u4'], followingIds:['u2','u5'] },
  { id:'u2', name:'Rahul Verma', username:'@rahulv', avatar:'🧑‍💻', bio:'Full Stack Dev | Coffee ☕ Lover.', followers:892, following:201, posts:31, online:false, samplePosts:['💻','⚡','🚀','☕','🔥','🛠️'], followerIds:['u1','u5'], followingIds:['u1','u3','u4'] },
  { id:'u3', name:'Ananya Singh', username:'@ananya_s', avatar:'🦸', bio:'Traveller ✈️ | Foodie 🍕 | Delhi.', followers:2180, following:543, posts:89, online:true, samplePosts:['✈️','🍕','🌍','🏖️','🗺️','🌄'], followerIds:['u1','u2','u4'], followingIds:['u1','u2','u5'] },
  { id:'u4', name:'Vikram Patel', username:'@vikram_p', avatar:'👨‍🚀', bio:'Photographer | Stars & Sunsets 🌅.', followers:3401, following:120, posts:156, online:false, samplePosts:['📸','🌌','🌅','🌙','⭐','🔭'], followerIds:['u3','u5'], followingIds:['u1','u3'] },
  { id:'u5', name:'Meera Nair', username:'@meeranair', avatar:'🧙', bio:'Writer ✍️ | Book lover 📚 | Pune.', followers:567, following:234, posts:22, online:true, samplePosts:['📚','✍️','🌿','☕','🕯️','🦋'], followerIds:['u2','u4'], followingIds:['u1','u4'] },
];
const coverColors = { u1:'linear-gradient(135deg,#1a0533,#3d1040,#1a2040)', u2:'linear-gradient(135deg,#001a33,#0d2040,#001a1a)', u3:'linear-gradient(135deg,#331a00,#402010,#1a3300)', u4:'linear-gradient(135deg,#0a0a2e,#1a0a3d,#0a1a2e)', u5:'linear-gradient(135deg,#0a1a0a,#1a2a10,#0a1520)' };
const sampleChats = { u1:[{from:'u1',text:'Hey! Kya haal hai?',time:'10:30'},{from:'u1',text:'Aaj kuch plan hai kya?',time:'10:31'}], u3:[{from:'u3',text:'Goa trip ke baare mein baat karni thi!',time:'kal'}] };

function seedStories() {
  const now = Date.now();
  stories = [
    {id:'s1',userId:'u1',emoji:'🌸',caption:'Aaj bahut sundar subah!',time:now-600000,bg:'',viewers:[]},
    {id:'s2',userId:'u1',emoji:'🎨',caption:'Naya painting bana rahi hoon',time:now-300000,bg:'style2',viewers:[]},
    {id:'s3',userId:'u3',emoji:'✈️',caption:'Goa ja rahi hoon! 🏖️',time:now-1800000,bg:'style3',viewers:[]},
    {id:'s4',userId:'u4',emoji:'🌌',caption:'Raat ka aasmaan',time:now-900000,bg:'style4',viewers:[]},
    {id:'s5',userId:'u5',emoji:'📚',caption:'Naya novel shuru kiya!',time:now-3600000,bg:'style5',viewers:[]},
  ];
}
const getUserStories = uid => stories.filter(s => s.userId === uid);

// ═══════════════════════════════════════════════
// CREDITS
// ═══════════════════════════════════════════════
function addCredit(n, reason) {
  credits += n;
  updateCreditDisplay();
  if (reason) showToast('⚡ +' + n + ' Credit! ' + reason);
}
function spendCredit(n) {
  if (credits < n) return false;
  credits -= n;
  updateCreditDisplay();
  return true;
}
function updateCreditDisplay() {
  document.getElementById('creditDisplay').textContent = credits;
  const el = document.getElementById('creditModalNum');
  if (el) el.textContent = credits;
}
function openCreditModal() {
  document.getElementById('creditModalNum').textContent = credits;
  document.getElementById('creditModal').classList.add('open');
}
function closeCreditModal() { document.getElementById('creditModal').classList.remove('open'); }

// ═══════════════════════════════════════════════
// SETUP
// ═══════════════════════════════════════════════
document.querySelectorAll('#avatarPick .av-opt').forEach(el => el.addEventListener('click', () => {
  document.querySelectorAll('#avatarPick .av-opt').forEach(e => e.classList.remove('selected'));
  el.classList.add('selected'); selectedAvatar = el.dataset.av;
}));
document.querySelector('#avatarPick .av-opt').classList.add('selected');

document.querySelectorAll('#editAvatarPick .av-opt').forEach(el => el.addEventListener('click', () => {
  document.querySelectorAll('#editAvatarPick .av-opt').forEach(e => e.classList.remove('selected'));
  el.classList.add('selected'); editAvatar = el.dataset.av;
}));

document.querySelectorAll('#emojiPicker .ep-opt').forEach(el => el.addEventListener('click', () => {
  document.querySelectorAll('#emojiPicker .ep-opt').forEach(e => e.classList.remove('selected'));
  el.classList.add('selected'); selectedStoryEmoji = el.dataset.e;
}));
document.querySelector('#emojiPicker .ep-opt').classList.add('selected');

function createProfile() {
  const name = document.getElementById('setupName').value.trim();
  const username = document.getElementById('setupUsername').value.trim();
  const bio = document.getElementById('setupBio').value.trim();
  if (!name || !username) { showToast('Naam aur username zaroor bharo!'); return; }
  me = { id:'me', name, username: username.startsWith('@') ? username : '@'+username, avatar: selectedAvatar, bio: bio||'Naya member!' };
  chats = JSON.parse(JSON.stringify(sampleChats));
  seedStories();
  document.getElementById('setupScreen').classList.remove('active');
  document.getElementById('mainScreen').classList.add('active');
  renderUserGrid(); renderChatList(); renderStoryRow();
  // Welcome credits
  credits = 10;
  updateCreditDisplay();
  showToast('Welcome ' + me.name + '! ⚡10 credits mile!');
}

// ═══════════════════════════════════════════════
// NAV
// ═══════════════════════════════════════════════
function showPage(pageId) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById(pageId).classList.add('active');
  const navMap = {explorePage:'nav-explore',chatPage:'nav-chat',profilePage:'nav-profile'};
  if (navMap[pageId]) document.getElementById(navMap[pageId]).classList.add('active');
  if (pageId === 'profilePage') renderProfile();
  // Daily login bonus
  if (pageId === 'explorePage' && !window._dailyBonusDone) { window._dailyBonusDone = true; addCredit(5, 'Daily login bonus!'); }
}

// ═══════════════════════════════════════════════
// STORY ROW
// ═══════════════════════════════════════════════
function renderStoryRow() {
  const row = document.getElementById('storyRow');
  const myStories = getUserStories('me');
  const myHas = myStories.length > 0;
  let html = `<div class="story-bubble-wrap my-story-wrap" onclick="${myHas?'viewMyStories()':'openStoryCreate()'}">
    <div class="story-ring ${myHas?'my-story':''}" style="${!myHas?'background:var(--border)':''}">
      <div class="story-inner">${me?me.avatar:'👤'}</div>
    </div>
    <div class="story-label">Meri Story</div>
    ${!myHas?'<div class="story-add-btn">+</div>':''}
  </div>`;
  sampleUsers.forEach(u => {
    const us = getUserStories(u.id);
    if (!us.length) return;
    const allSeen = us.every(s => seenStories.has(s.id));
    html += `<div class="story-bubble-wrap" onclick="viewUserStories('${u.id}')">
      <div class="story-ring ${allSeen?'seen':''}"><div class="story-inner">${u.avatar}</div></div>
      <div class="story-label">${u.name.split(' ')[0]}</div>
    </div>`;
  });
  row.innerHTML = html;
}
function renderMyStoryRow() {
  const row = document.getElementById('myStoryRow');
  const ms = getUserStories('me');
  if (!ms.length) { row.innerHTML = '<div style="color:var(--muted);font-size:13px;padding:8px 0;">Abhi koi story nahi.</div>'; return; }
  row.innerHTML = ms.map(s => `<div class="story-bubble-wrap" onclick="viewMyStories()">
    <div class="story-ring my-story"><div class="story-inner">${s.emoji}</div></div>
    <div class="story-label">${s.caption?s.caption.substring(0,10)+'…':'Story'}</div>
  </div>`).join('');
}

// ═══════════════════════════════════════════════
// STORY VIEWER
// ═══════════════════════════════════════════════
function viewUserStories(uid) { const us = getUserStories(uid); if (!us.length) return; storyQueue = us; currentStorySlide = 0; openStoryViewer(uid, 0); }
function viewMyStories() { const ms = getUserStories('me'); if (!ms.length) { openStoryCreate(); return; } storyQueue = ms; currentStorySlide = 0; openStoryViewer('me', 0); }

function openStoryViewer(uid, idx) {
  currentStorySlide = idx;
  const story = storyQueue[idx];
  const u = uid==='me' ? me : sampleUsers.find(u=>u.id===uid);
  if (!u||!story) return;
  document.getElementById('storyViewer').classList.add('open');
  document.getElementById('svAvatar').textContent = u.avatar;
  document.getElementById('svName').textContent = u.name;
  document.getElementById('svTime').textContent = formatStoryTime(story.time);
  const content = document.getElementById('svContent');
  content.className = 'sv-content' + (story.bg?' '+story.bg:'');
  content.innerHTML = `<span style="font-size:120px">${story.emoji}</span><div class="sv-story-text">${story.caption||''}</div>`;
  seenStories.add(story.id);
  if (uid!=='me' && !story.viewers.find(v=>v.id==='me')) {
    story.viewers.push({id:'me',name:me.name,avatar:me.avatar,seenAt:Date.now()});
  }
  if (uid!=='me') {
    sampleUsers.filter(su=>su.id!==uid).forEach(pv => {
      if (Math.random()>.4 && !story.viewers.find(v=>v.id===pv.id))
        story.viewers.push({id:pv.id,name:pv.name,avatar:pv.avatar,seenAt:Date.now()-Math.random()*3600000});
    });
  }
  const pr = document.getElementById('svProgressRow');
  pr.innerHTML = storyQueue.map((_,i) => `<div class="sv-progress-bar"><div class="sv-progress-fill" id="spf${i}" style="width:${i<idx?'100%':'0%'}"></div></div>`).join('');
  document.getElementById('svViewerCount').textContent = story.viewers.length;
  renderStoryRow(); startStoryProgress();
}
function startStoryProgress() {
  clearTimeout(storyTimer);
  const fill = document.getElementById('spf'+currentStorySlide);
  if (fill) { fill.style.transition='none'; fill.style.width='0%'; setTimeout(()=>{ fill.style.transition=`width ${STORY_DURATION}ms linear`; fill.style.width='100%'; },50); }
  storyTimer = setTimeout(nextStory, STORY_DURATION);
}
function nextStory() { clearTimeout(storyTimer); if (currentStorySlide<storyQueue.length-1) { currentStorySlide++; openStoryViewer(storyQueue[currentStorySlide].userId,currentStorySlide); } else closeStoryViewer(); }
function prevStory() { clearTimeout(storyTimer); if (currentStorySlide>0) { currentStorySlide--; openStoryViewer(storyQueue[currentStorySlide].userId,currentStorySlide); } }
function closeStoryViewer() { clearTimeout(storyTimer); document.getElementById('storyViewer').classList.remove('open'); renderStoryRow(); }
function formatStoryTime(ts) { const d=Date.now()-ts; if(d<60000)return'Abhi abhi'; if(d<3600000)return Math.floor(d/60000)+' min pehle'; if(d<86400000)return Math.floor(d/3600000)+' ghante pehle'; return'Kal'; }
function openStoryViewers() {
  const story = storyQueue[currentStorySlide];
  if (!story) return;
  const list = document.getElementById('svsList');
  list.innerHTML = !story.viewers.length
    ? '<div class="empty-state"><div class="empty-icon">👁</div>Abhi kisi ne nahi dekha</div>'
    : story.viewers.map(v=>`<div class="svs-item"><div class="svs-av">${v.avatar}</div><div class="svs-info"><div class="svs-name">${v.name}</div><div class="svs-time">${formatStoryTime(v.seenAt)}</div></div></div>`).join('');
  document.getElementById('storyViewersSheet').classList.add('open');
}
function closeStoryViewers() { document.getElementById('storyViewersSheet').classList.remove('open'); }
function openStoryCreate() { document.getElementById('storyCaptionInput').value=''; document.getElementById('storyCreateModal').classList.add('open'); }
function closeStoryCreate() { document.getElementById('storyCreateModal').classList.remove('open'); }
function postStory() {
  const caption = document.getElementById('storyCaptionInput').value.trim();
  stories.unshift({id:'ms_'+Date.now(),userId:'me',emoji:selectedStoryEmoji,caption,time:Date.now(),bg:storyBgs[Math.floor(Math.random()*storyBgs.length)],viewers:[]});
  closeStoryCreate(); renderStoryRow(); renderMyStoryRow();
  addCredit(3, 'Story daali!');
  setTimeout(()=>viewMyStories(),300);
}

// ═══════════════════════════════════════════════
// PEOPLE PANEL
// ═══════════════════════════════════════════════
let currentPeoplePanelUid = null, currentPeoplePanelTab = 'followers';
function openPeoplePanel(tab, uid) {
  currentPeoplePanelUid = uid; currentPeoplePanelTab = tab;
  document.getElementById('peoplePanel').classList.add('open');
  switchPeopleTab(tab);
}
function closePeoplePanel() { document.getElementById('peoplePanel').classList.remove('open'); }
function switchPeopleTab(tab) {
  currentPeoplePanelTab = tab;
  document.getElementById('ppTabFollowers').classList.toggle('active',tab==='followers');
  document.getElementById('ppTabFollowing').classList.toggle('active',tab==='following');
  document.getElementById('ppTitle').textContent = tab==='followers'?'Followers':'Following';
  renderPeopleList();
}
function renderPeopleList() {
  const list = document.getElementById('ppList');
  const uid = currentPeoplePanelUid;
  let people = [];
  if (uid==='me') {
    people = sampleUsers.filter(u=>following.has(u.id));
    if (!people.length) { list.innerHTML='<div class="empty-state"><div class="empty-icon">😔</div>Abhi koi nahi</div>'; return; }
  } else {
    const u = sampleUsers.find(su=>su.id===uid); if(!u) return;
    const ids = currentPeoplePanelTab==='followers' ? u.followerIds : u.followingIds;
    people = (ids||[]).map(id=>sampleUsers.find(su=>su.id===id)).filter(Boolean);
    if (!people.length) { list.innerHTML='<div class="empty-state"><div class="empty-icon">👤</div>Koi nahi</div>'; return; }
  }
  list.innerHTML = people.map(p=>`<div class="pp-item" onclick="closePeoplePanel();openUserProfile('${p.id}')">
    <div class="pp-av">${p.avatar}</div>
    <div class="pp-info"><div class="pp-name">${p.name}</div><div class="pp-username">${p.username}</div></div>
    <button class="pp-follow-btn ${following.has(p.id)?'following':''}" onclick="event.stopPropagation();ppToggleFollow('${p.id}',this)">${following.has(p.id)?'✓':'+ Follow'}</button>
  </div>`).join('');
}
function ppToggleFollow(uid,btn) {
  if(following.has(uid)){following.delete(uid);btn.textContent='+ Follow';btn.classList.remove('following');showToast('Unfollow kar diya');}
  else{following.add(uid);btn.textContent='✓';btn.classList.add('following');addCredit(2,'Follow kiya!');}
  renderProfile();renderUserGrid();renderChatList();
}

// ═══════════════════════════════════════════════
// EXPLORE
// ═══════════════════════════════════════════════
function renderUserGrid(filter='') {
  const grid = document.getElementById('userGrid');
  const filtered = sampleUsers.filter(u=>u.name.toLowerCase().includes(filter.toLowerCase())||u.username.includes(filter.toLowerCase()));
  if (!filtered.length) { grid.innerHTML='<div class="empty-state"><div class="empty-icon">🔍</div>Koi nahi mila</div>'; return; }
  grid.innerHTML = filtered.map(u=>`<div class="user-card">
    <div class="user-card-av" onclick="openUserProfile('${u.id}')">${u.avatar}</div>
    <div class="user-card-info" onclick="openUserProfile('${u.id}')">
      <div class="user-card-name">${u.name} ${u.online?'<span style="color:var(--online);font-size:10px">● Online</span>':''}</div>
      <div class="user-card-bio">${u.bio.split('.')[0]}</div>
      <div style="margin-top:4px"><span class="tag">${u.followers.toLocaleString()} followers</span><span class="tag">${u.posts} posts</span></div>
    </div>
    <button class="follow-btn ${following.has(u.id)?'following':''}" onclick="toggleFollow('${u.id}',this)">${following.has(u.id)?'✓':'+'}</button>
  </div>`).join('');
}
function filterUsers() { renderUserGrid(document.getElementById('searchBar').value); }
function toggleFollow(uid,btn) {
  if(following.has(uid)){following.delete(uid);if(btn){btn.textContent='+';btn.classList.remove('following');}showToast('Unfollow kar diya');}
  else{following.add(uid);if(btn){btn.textContent='✓';btn.classList.add('following');}addCredit(2,'Naya follow!');renderChatList();}
  if(currentViewUserId===uid)updateProfilePanelFollowBtn();
  renderProfile();
}

// ═══════════════════════════════════════════════
// USER PROFILE
// ═══════════════════════════════════════════════
function openUserProfile(uid) {
  const u = sampleUsers.find(u=>u.id===uid); if(!u) return;
  currentViewUserId = uid;
  document.getElementById('upTopbarName').textContent = u.username;
  document.getElementById('upCoverBg').style.background = coverColors[uid]||'linear-gradient(135deg,#1a1a3d,#3d1a1a)';
  document.getElementById('upAvatar').textContent = u.avatar;
  document.getElementById('upName').textContent = u.name;
  document.getElementById('upUsername').textContent = u.username;
  document.getElementById('upBio').textContent = u.bio;
  document.getElementById('upPosts').textContent = u.posts;
  document.getElementById('upFollowers').textContent = u.followers.toLocaleString();
  document.getElementById('upFollowing').textContent = u.following.toLocaleString();
  document.getElementById('upOnlineBadge').innerHTML = u.online?'<div class="up-online-badge"><span>●</span> Online</div>':'';
  updateProfilePanelFollowBtn();
  document.getElementById('upPostsGrid').innerHTML = (u.samplePosts||['📸','🌟','✨','🎉','🔥','💫']).map(e=>`<div class="up-post-thumb">${e}</div>`).join('');
  document.getElementById('userProfilePanel').classList.add('open');
  document.getElementById('userProfilePanel').scrollTop = 0;
}
function updateProfilePanelFollowBtn() {
  const btn = document.getElementById('upFollowBtn');
  const isF = following.has(currentViewUserId);
  btn.textContent = isF?'✓ Following':'+ Follow';
  btn.classList.toggle('following',isF);
}
function toggleFollowFromProfile() { const uid=currentViewUserId; if(!uid) return; const gb=document.querySelector(`#userGrid .follow-btn[onclick*="${uid}"]`); toggleFollow(uid,gb); }
function msgFromProfile() { closeUserProfile(); openChat(currentViewUserId); }
function closeUserProfile() { document.getElementById('userProfilePanel').classList.remove('open'); }

// ═══════════════════════════════════════════════
// CHAT
// ═══════════════════════════════════════════════
function renderChatList() {
  const list = document.getElementById('chatList');
  const chatUsers = sampleUsers.filter(u=>chats[u.id]||following.has(u.id));
  if (!chatUsers.length) { list.innerHTML='<div class="empty-state"><div class="empty-icon">💬</div>Kisi ko follow karo aur chat karo!</div>'; return; }
  list.innerHTML = chatUsers.map(u=>{
    const msgs=chats[u.id]||[];
    const last=msgs[msgs.length-1];
    const unread=msgs.filter(m=>m.from!=='me'&&!m.read).length;
    return `<div class="chat-item" onclick="openChat('${u.id}')">
      <div class="chat-av">${u.avatar}${u.online?'<div class="online-dot"></div>':''}</div>
      <div class="chat-info"><div class="chat-name">${u.name}</div><div class="chat-preview">${last?last.text:'Message bhejo!'}</div></div>
      <div class="chat-meta"><div class="chat-time">${last?last.time:''}</div>${unread?`<div class="chat-badge">${unread}</div>`:''}</div>
    </div>`;
  }).join('');
}
function openChat(uid) {
  const u=sampleUsers.find(u=>u.id===uid); currentChatUser=u;
  if(!chats[uid])chats[uid]=[];
  chats[uid].forEach(m=>m.read=true);
  document.getElementById('chatUserAv').textContent=u.avatar;
  document.getElementById('chatUserName').textContent=u.name;
  document.getElementById('chatWindow').classList.add('open');
  renderMessages(); document.getElementById('chatInput').focus();
}
function closeChatWindow() { document.getElementById('chatWindow').classList.remove('open'); renderChatList(); }

function renderMessages() {
  const uid=currentChatUser.id, msgs=chats[uid]||[];
  const container=document.getElementById('chatMessages');
if (!msgs.length) { container.innerHTML=`<div class="empty-state" style="padding:60px 20px"><div class="empty-icon">👋</div>${currentChatUser.name} ko message karo!</div>`; return; }
  container.innerHTML = msgs.map(m=>{
    if (m.type==='photo') {
      if (m.viewed) return `<div class="msg-photo-deleted"><span>🔒</span><span style="font-size:13px;color:var(--muted)">Photo delete ho gayi (ek baar dekha)</span></div>`;
      return `<div class="msg-photo" onclick="viewPhoto('${m.id}')">
        <div class="msg-photo-inner">
          <div class="msg-photo-emoji">${m.emoji}</div>
          <div class="msg-photo-overlay">
            <span style="font-size:28px">👆</span>
            <div class="msg-photo-tap">Tap karke dekho</div>
            <div class="msg-photo-credits">🔒 View Once</div>
          </div>
        </div>
        <div style="font-size:11px;color:var(--muted);margin-top:4px;text-align:right">${m.time}</div>
      </div>`;
    }
    return `<div><div class="msg-bubble ${m.from==='me'?'sent':'received'}">${m.text}<div class="msg-time">${m.time}</div></div></div>`;
  }).join('');
  container.scrollTop = container.scrollHeight;
}

function sendMsg() {
  const input=document.getElementById('chatInput');
  const text=input.value.trim(); if(!text||!currentChatUser) return;
  const uid=currentChatUser.id;
  if(!chats[uid])chats[uid]=[];
  const now=new Date(), time=now.getHours()+':'+String(now.getMinutes()).padStart(2,'0');
  chats[uid].push({from:'me',text,time,read:true});
  input.value=''; renderMessages();
  addCredit(1, ''); // silent +1
  const replies=['Haan bilkul! 😊','Bahut achha laga! 🙌','Sahi kaha yaar! 💯','Haha 😂','Kal milte hain! 👋','Amazing! 🔥','🎉🎉','Hmm...'];
  setTimeout(()=>{
    chats[uid].push({from:uid,text:replies[Math.floor(Math.random()*replies.length)],time,read:true});
    if(document.getElementById('chatWindow').classList.contains('open')&&currentChatUser?.id===uid) renderMessages();
  },1000+Math.random()*1000);
}

// ═══════════════════════════════════════════════
// PHOTO SEND (View Once, 1 Credit)
// ═══════════════════════════════════════════════
const photoEmojis = ['🌺','🎆','🌟','🏖️','🎭','🌈','🍜','🎸','🌙','⛰️'];
function initiatePhotoSend() {
  pendingPhotoEmoji = photoEmojis[Math.floor(Math.random()*photoEmojis.length)];
  document.getElementById('photoPreviewEmoji').textContent = pendingPhotoEmoji;
  document.getElementById('photoConfirmModal').classList.add('open');
}
function closePhotoConfirm() { document.getElementById('photoConfirmModal').classList.remove('open'); }
function confirmSendPhoto() {
  if (credits < 1) { closePhotoConfirm(); showToast('⚡ Credits nahi hain! Pehle earn karo.'); return; }
  if (!spendCredit(1)) { closePhotoConfirm(); showToast('Credit nahi hai!'); return; }
  closePhotoConfirm();
  const uid=currentChatUser.id;
  if(!chats[uid])chats[uid]=[];
  const now=new Date(), time=now.getHours()+':'+String(now.getMinutes()).padStart(2,'0');
  const photoId = 'ph_'+Date.now();
  chats[uid].push({id:photoId,from:'me',type:'photo',emoji:pendingPhotoEmoji,time,read:true,viewed:false});
  renderMessages();
  showToast('📷 Photo bhej di! ⚡-1 credit');
}
function viewPhoto(photoId) {
  const uid=currentChatUser.id;
  const msg = (chats[uid]||[]).find(m=>m.id===photoId);
  if (!msg||msg.viewed) return;
  // Show fullscreen then delete
  const overlay = document.createElement('div');
  overlay.style.cssText = 'position:fixed;inset:0;z-index:2000;background:#000;display:flex;flex-direction:column;align-items:center;justify-content:center;';
  overlay.innerHTML = `<div style="font-size:140px;animation:bubbleIn .3s ease">${msg.emoji}</div>
    <div style="color:rgba(255,255,255,.6);font-size:13px;margin-top:20px;">🔒 Ye photo 3 seconds mein delete ho jaayegi</div>
    <div style="width:200px;height:3px;background:rgba(255,255,255,.2);border-radius:2px;margin-top:14px;overflow:hidden">
      <div style="height:100%;background:var(--accent2);transition:width 3s linear;width:0%" id="photoTimer"></div>
    </div>`;
  document.body.appendChild(overlay);
  setTimeout(()=>{ const pb=document.getElementById('photoTimer'); if(pb){pb.style.width='100%';} },50);
  setTimeout(()=>{
    overlay.remove();
    msg.viewed = true;
    renderMessages();
    showToast('🔒 Photo delete ho gayi!');
  },3000);
}

// ═══════════════════════════════════════════════
// CALL SCREEN
// ═══════════════════════════════════════════════
function startCall(type) {
  callType = type;
  const u = currentChatUser; if(!u) return;
  document.getElementById('callAvatar').textContent = u.avatar;
  document.getElementById('callName').textContent = u.name;
  document.getElementById('callTypeBadge').textContent = type==='video'?'📹 Video Call':'📞 Audio Call';
  document.getElementById('callStatusTxt').textContent = 'Connecting...';
  document.getElementById('camBtn').style.display = type==='video'?'flex':'none';
  const videoSelf = document.getElementById('videoSelf');
  if (type==='video') { videoSelf.style.display='flex'; videoSelf.textContent=me?me.avatar:'👤'; }
  else videoSelf.style.display='none';
  isMuted=false; isCameraOff=false;
  document.getElementById('muteBtn').textContent='🎙️';
  document.getElementById('callScreen').classList.add('open');
  // Simulate connecting → connected
  callSeconds = 0;
  setTimeout(()=>{
    document.getElementById('callStatusTxt').textContent='00:00';
    callTimer = setInterval(()=>{
      callSeconds++;
      const m=String(Math.floor(callSeconds/60)).padStart(2,'0');
      const s=String(callSeconds%60).padStart(2,'0');
      const el=document.getElementById('callStatusTxt');
      if(el) el.textContent=m+':'+s;
    },1000);
  },1500);
}
function endCall() {
  clearInterval(callTimer);
  document.getElementById('callScreen').classList.remove('open');
  const dur = callSeconds>0 ? (Math.floor(callSeconds/60)+'m '+callSeconds%60+'s') : '';
  showToast('Call khatam! ' + (dur?'Duration: '+dur:''));
}
function toggleMute() {
  isMuted=!isMuted;
  document.getElementById('muteBtn').textContent=isMuted?'🔇':'🎙️';
  showToast(isMuted?'Mute on':'Mute off');
}
function toggleCamera() {
  isCameraOff=!isCameraOff;
  document.getElementById('camBtn').textContent=isCameraOff?'🚫':'📷';
  showToast(isCameraOff?'Camera off':'Camera on');
}

// ═══════════════════════════════════════════════
// MY PROFILE
// ═══════════════════════════════════════════════
function renderProfile() {
  if(!me) return;
  document.getElementById('myProfileAvatar').textContent=me.avatar;
  document.getElementById('myProfileName').textContent=me.name;
  document.getElementById('myProfileUsername').textContent=me.username;
  document.getElementById('myProfileBio').textContent=me.bio;
  document.getElementById('statPosts').textContent=myPosts.length;
  document.getElementById('statFollowers').textContent=following.size;
  document.getElementById('statFollowing').textContent=following.size;
  renderMyStoryRow();
  const feed=document.getElementById('myPostsFeed');
  feed.innerHTML=!myPosts.length?'<div class="empty-state"><div class="empty-icon">📝</div>Abhi tak koi post nahi!</div>':myPosts.map(p=>postHTML(p)).join('');
}
function postHTML(p) {
  return `<div class="post-card"><div class="post-header"><div class="post-avatar">${me.avatar}</div><div class="post-meta"><div class="post-username">${me.name}</div><div class="post-time">${me.username} · ${p.time}</div></div></div>
  <div class="post-image">${p.emoji}</div>
  <div class="post-body"><div class="post-text">${p.text}</div>
  <div class="post-actions">
    <button class="action-btn ${p.liked?'liked':''}" onclick="likePost('${p.id}')"><span class="icon">${p.liked?'❤️':'🤍'}</span> ${p.likes}</button>
    <button class="action-btn" onclick="showToast('Comment feature aa raha hai!')"><span class="icon">💬</span> ${p.comments}</button>
    <button class="action-btn" onclick="showToast('Share ho gaya! 🔗')"><span class="icon">🔗</span> Share</button>
  </div></div></div>`;
}
function likePost(id) { const p=myPosts.find(p=>p.id===id); if(!p) return; p.liked=!p.liked; p.likes+=p.liked?1:-1; renderProfile(); }
function openEditModal() {
  document.getElementById('editName').value=me.name; document.getElementById('editBio').value=me.bio; editAvatar=me.avatar;
  document.querySelectorAll('#editAvatarPick .av-opt').forEach(el=>el.classList.toggle('selected',el.dataset.av===me.avatar));
  document.getElementById('editModal').classList.add('open');
}
function closeEditModal() { document.getElementById('editModal').classList.remove('open'); }
function saveEdit() {
  const name=document.getElementById('editName').value.trim(); if(!name){showToast('Naam zaroor likho!');return;}
  me.name=name; me.bio=document.getElementById('editBio').value.trim();
  if(editAvatar)me.avatar=editAvatar;
  closeEditModal(); renderProfile(); showToast('Profile update ho gaya! ✅');
}

// ═══════════════════════════════════════════════
// TOAST
// ═══════════════════════════════════════════════
let toastTimer;
function showToast(msg) {
  const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show');
  clearTimeout(toastTimer); toastTimer=setTimeout(()=>t.classList.remove('show'),2500);
}

// Event listeners
document.getElementById('editModal').addEventListener('click',e=>{if(e.target===document.getElementById('editModal'))closeEditModal();});
document.getElementById('storyCreateModal').addEventListener('click',e=>{if(e.target===document.getElementById('storyCreateModal'))closeStoryCreate();});
document.getElementById('storyViewersSheet').addEventListener('click',e=>{if(e.target===document.getElementById('storyViewersSheet'))closeStoryViewers();});
document.getElementById('creditModal').addEventListener('click',e=>{if(e.target===document.getElementById('creditModal'))closeCreditModal();});
document.getElementById('photoConfirmModal').addEventListener('click',e=>{if(e.target===document.getElementById('photoConfirmModal'))closePhotoConfirm();});
document.getElementById('chatInput').addEventListener('keydown',e=>{if(e.key==='Enter')sendMsg();});
</script>
