  #userProfilePanel.open { transform:translateX(0); }
  .up-topbar { position:sticky; top:0; z-index:10; background:rgba(10,10,15,.9); backdrop-filter:blur(20px); border-bottom:1px solid var(--border); padding:12px 16px; display:flex; align-items:center; gap:12px; }
  .up-cover { height:160px; position:relative; overflow:hidden; flex-shrink:0; }
